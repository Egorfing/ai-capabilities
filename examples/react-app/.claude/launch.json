{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["json-server", "--watch", "server/db.json", "--port", "4001"],
      "port": 4001
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "express-app",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "../express-app/server.ts"],
      "port": 3000,
      "env": {
        "RUN_CLIENT_DEMO": "false",
        "DOTENV_CONFIG_PATH": "../express-app/.env"
      }
    }
  ]
}
