{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "baseUrl": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "ai-capabilities": ["../../dist/index.browser.d.ts"],
      "ai-capabilities/*": ["../../dist/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
